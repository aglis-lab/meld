{
  "name": "@aglis-lab/meld-ts",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript runtime and benchmark tooling for Meld TEF templates",
  "type": "module",
  "scripts": {
    "bench": "bun run cmd/bench/main.ts",
    "bench:node": "node cmd/bench/main.ts",
    "bench:deno": "deno run --allow-read cmd/bench/main.ts",
    "example": "bun run cmd/example/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "tinybench": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.17.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
